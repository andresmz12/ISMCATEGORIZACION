generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  SUPERADMIN
  ACCOUNTANT
  TEAM_MEMBER
}

enum Plan {
  // No active subscription and nothing granted by an admin — every paid
  // feature is blocked and the account is redirected to billing. BASIC is
  // a real $20/mo paid tier, not a free default, so it must never be the
  // fallback for "hasn't paid yet".
  NONE
  BASIC
  PLUS
  ENTERPRISE
  CUSTOM
}

enum Role {
  OWNER
  MANAGER
  VIEWER
}

enum TxType {
  DEBIT
  CREDIT
}

enum TxStatus {
  PENDING
  CLASSIFIED
  NEEDS_REVIEW
}

enum Deductibility {
  YES
  NO
  FIFTY
}

enum ClassMethod {
  MANUAL
  AI
  RULE
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AccountRole {
  OWNER
  MEMBER
}

// The billing/subscription anchor. One Square customer & subscription maps to
// one BillingAccount; every User that belongs to it (owner + invited team
// members) shares its `plan`. Not to be confused with `Business` (a client
// company the firm tracks transactions for) or NextAuth's `Account` model
// below (OAuth-linked accounts) — named differently only to avoid clashing
// with that pre-existing Prisma model.
model BillingAccount {
  id                   String    @id @default(cuid())
  name                 String?
  plan                 Plan      @default(NONE)
  squareCustomerId     String?   @unique
  squareSubscriptionId String?   @unique
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?
  // Set when a checkout is started (the order_id CreatePaymentLink returns
  // synchronously, plus the plan that checkout was for) and cleared once the
  // matching invoice.payment_made webhook arrives — this is how we correlate
  // that webhook back to this account, since Square's subscription-checkout
  // shortcut has no reference_id we can pass through ourselves.
  pendingSquareOrderId String?   @unique
  pendingSquarePlan    Plan?
  // New self-registrations get a 7-day trial: plan stays NONE (they still
  // haven't paid, so admin views / "granted a plan" semantics stay honest),
  // but lib/billing-access.ts treats the account as BASIC-equivalent for
  // feature access until this passes. Null for accounts that never had a
  // trial (admin-granted, pre-trial-feature accounts, or already paying).
  trialEndsAt          DateTime?
  // AI budget and chatbot access are account-wide, not per-business — an
  // account can own several businesses, and this is the one shared bucket
  // that applies to every business and team member under it. See lib/account.ts.
  aiMonthlyBudgetCents Int?
  chatbotEnabled       Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  users                User[]
  aiUsage              AiUsage[]
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  name            String?
  accountType     AccountType @default(ACCOUNTANT)
  accountId       String
  accountRole     AccountRole @default(MEMBER)
  isActive        Boolean     @default(true)
  lastLogin       DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  inviteToken           String?   @unique
  inviteTokenExpiresAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  billingAccount      BillingAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  businessUsers       BusinessUser[]
  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  uploadedDocuments   Document[]
  assignmentsAssigned Assignment[] @relation("AssignedTo")
  assignmentsCreated  Assignment[] @relation("CreatedBy")
  assignmentNotes     AssignmentNote[]

  @@index([accountId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id                   String               @id @default(cuid())
  name                 String
  industry             String?
  entityType           String?
  taxYear              Int?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  users            BusinessUser[]
  transactions     Transaction[]
  categories       Category[]
  bankMappings     BankFormatMapping[]
  rules            ClassificationRule[]
  documentTypes    DocumentType[]
  documents        Document[]
  assignments      Assignment[]
  plaidConnections PlaidConnection[]
}

// Scoped to the BillingAccount (not Business) — an account's AI spend is
// shared across every business it owns. See lib/account.ts.
model AiUsage {
  id                String         @id @default(cuid())
  accountId         String
  period            String
  inputTokens       Int            @default(0)
  outputTokens      Int            @default(0)
  costCents         Int            @default(0)
  classifiedCount   Int            @default(0)
  blocked           Boolean        @default(false)
  unblockedByAdmin  Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  billingAccount    BillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, period])
  @@index([accountId])
}

model BusinessUser {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       Role     @default(VIEWER)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

model Transaction {
  id            String            @id @default(cuid())
  businessId    String
  date          DateTime
  description   String
  amount        Float
  type          TxType            @default(DEBIT)
  status        TxStatus          @default(PENDING)
  categoryId    String?
  deductibility Deductibility?
  method        ClassMethod?
  aiConfidence  String?
  aiSuggestion  String?
  notes              String?
  sourceFile         String?
  checksum           String?
  plaidTransactionId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  business           Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category           Category?         @relation(fields: [categoryId], references: [id])
  splits             TransactionSplit[]

  @@index([businessId, status])
  @@index([businessId, date])
  @@index([businessId, categoryId])
  @@index([categoryId])
  @@unique([businessId, checksum])
  @@unique([plaidTransactionId])
}

model TransactionSplit {
  id            String         @id @default(cuid())
  transactionId String
  categoryId    String
  amount        Float
  deductibility Deductibility?
  notes         String?
  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
  @@index([categoryId])
}

model Category {
  id           String               @id @default(cuid())
  businessId   String?
  name         String
  irsCode      String?
  description  String?
  isSystem     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  business     Business?            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  splits       TransactionSplit[]
  rules        ClassificationRule[]

  @@index([businessId])
}

model ClassificationRule {
  id            String        @id @default(cuid())
  businessId    String
  pattern       String
  categoryId    String
  priority      Int           @default(0)
  field         String        @default("description")
  deductibility Deductibility?
  createdAt     DateTime      @default(now())
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id])

  @@index([businessId, priority])
}

model BankFormatMapping {
  id         String   @id @default(cuid())
  businessId String
  bankName   String
  mapping    Json
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model DocumentType {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  description String?
  required    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@index([businessId])
}

model Document {
  id             String       @id @default(cuid())
  businessId     String
  documentTypeId String
  filename       String
  data           String
  mimeType       String
  uploadedById   String
  notes          String?
  createdAt      DateTime     @default(now())
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  @@index([businessId])
  @@index([documentTypeId])
}

model Assignment {
  id           String           @id @default(cuid())
  businessId   String
  title        String
  description  String?
  status       AssignmentStatus @default(PENDING)
  assignedToId String?
  createdById  String
  dueDate      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedTo   User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy    User             @relation("CreatedBy", fields: [createdById], references: [id])
  notes        AssignmentNote[]

  @@index([businessId])
  @@index([assignedToId])
  @@index([status])
}

model AssignmentNote {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  note         String
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@index([assignmentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  businessId String?
  action     String
  entity     String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([businessId])
  @@index([createdAt])
}

model PlaidConnection {
  id              String        @id @default(cuid())
  businessId      String
  accessToken     String
  itemId          String
  institutionName String
  cursor          String?
  lastSyncAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  accounts        PlaidAccount[]

  @@index([businessId])
}

model PlaidAccount {
  id           String          @id @default(cuid())
  connectionId String
  plaidId      String
  name         String
  mask         String?
  type         String
  connection   PlaidConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, plaidId])
}
