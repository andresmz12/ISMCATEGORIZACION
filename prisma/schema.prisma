generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  SUPERADMIN
  ACCOUNTANT
  TEAM_MEMBER
}

enum Plan {
  BASIC
  PLUS
  ENTERPRISE
  CUSTOM
}

enum Role {
  OWNER
  MANAGER
  VIEWER
}

enum TxType {
  DEBIT
  CREDIT
}

enum TxStatus {
  PENDING
  CLASSIFIED
  NEEDS_REVIEW
}

enum Deductibility {
  YES
  NO
  FIFTY
}

enum ClassMethod {
  MANUAL
  AI
  RULE
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  name            String?
  firmName        String?
  accountType     AccountType @default(ACCOUNTANT)
  plan            Plan        @default(BASIC)
  isActive        Boolean     @default(true)
  lastLogin       DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  businessUsers       BusinessUser[]
  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  uploadedDocuments   Document[]
  assignmentsAssigned Assignment[] @relation("AssignedTo")
  assignmentsCreated  Assignment[] @relation("CreatedBy")
  assignmentNotes     AssignmentNote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id           String               @id @default(cuid())
  name         String
  industry     String?
  entityType   String?
  taxYear      Int?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  users            BusinessUser[]
  transactions     Transaction[]
  categories       Category[]
  bankMappings     BankFormatMapping[]
  rules            ClassificationRule[]
  documentTypes    DocumentType[]
  documents        Document[]
  assignments      Assignment[]
  plaidConnections PlaidConnection[]
}

model BusinessUser {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       Role     @default(VIEWER)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

model Transaction {
  id            String            @id @default(cuid())
  businessId    String
  date          DateTime
  description   String
  amount        Float
  type          TxType            @default(DEBIT)
  status        TxStatus          @default(PENDING)
  categoryId    String?
  deductibility Deductibility?
  method        ClassMethod?
  aiConfidence  String?
  aiSuggestion  String?
  notes              String?
  sourceFile         String?
  checksum           String?
  plaidTransactionId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  business           Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category           Category?         @relation(fields: [categoryId], references: [id])
  splits             TransactionSplit[]

  @@index([businessId, status])
  @@index([businessId, date])
  @@index([businessId, categoryId])
  @@index([categoryId])
  @@index([checksum])
  @@index([plaidTransactionId])
}

model TransactionSplit {
  id            String         @id @default(cuid())
  transactionId String
  categoryId    String
  amount        Float
  deductibility Deductibility?
  notes         String?
  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
  @@index([categoryId])
}

model Category {
  id           String               @id @default(cuid())
  businessId   String?
  name         String
  irsCode      String?
  description  String?
  isSystem     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  business     Business?            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  splits       TransactionSplit[]
  rules        ClassificationRule[]

  @@index([businessId])
}

model ClassificationRule {
  id            String        @id @default(cuid())
  businessId    String
  pattern       String
  categoryId    String
  priority      Int           @default(0)
  field         String        @default("description")
  deductibility Deductibility?
  createdAt     DateTime      @default(now())
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id])

  @@index([businessId, priority])
}

model BankFormatMapping {
  id         String   @id @default(cuid())
  businessId String
  bankName   String
  mapping    Json
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model DocumentType {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  description String?
  required    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@index([businessId])
}

model Document {
  id             String       @id @default(cuid())
  businessId     String
  documentTypeId String
  filename       String
  data           String
  mimeType       String
  uploadedById   String
  notes          String?
  createdAt      DateTime     @default(now())
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  @@index([businessId])
  @@index([documentTypeId])
}

model Assignment {
  id           String           @id @default(cuid())
  businessId   String
  title        String
  description  String?
  status       AssignmentStatus @default(PENDING)
  assignedToId String?
  createdById  String
  dueDate      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedTo   User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy    User             @relation("CreatedBy", fields: [createdById], references: [id])
  notes        AssignmentNote[]

  @@index([businessId])
  @@index([assignedToId])
  @@index([status])
}

model AssignmentNote {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  note         String
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@index([assignmentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  businessId String?
  action     String
  entity     String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([businessId])
  @@index([createdAt])
}

model PlaidConnection {
  id              String        @id @default(cuid())
  businessId      String
  accessToken     String
  itemId          String
  institutionName String
  cursor          String?
  lastSyncAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  accounts        PlaidAccount[]

  @@index([businessId])
}

model PlaidAccount {
  id           String          @id @default(cuid())
  connectionId String
  plaidId      String
  name         String
  mask         String?
  type         String
  connection   PlaidConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, plaidId])
}
