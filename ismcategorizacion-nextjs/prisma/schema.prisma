// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANT ARCHITECTURE
// ============================================================================

// LEVEL 1: Accountant/Firm (Tenant)
// The top-level organization. One Accountant can have multiple Businesses (clients).
model Accountant {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              User[]
  businesses         Business[]
  planCatalog        Plan[]
  subscriptions      Subscription[]
  bankFormatMappings BankFormatMapping[]

  @@map("accountants")
}

// LEVEL 2: Business (Client)
// Each business/client that belongs to an Accountant.
model Business {
  id             String   @id @default(cuid())
  accountantId   String
  subscriptionId String?  // Link to current subscription
  name           String
  industry       String   @default("Other")
  entityType     String   @default("Sole Proprietor (Schedule C)") // e.g., "S-Corp", "C-Corp", "LLC"
  taxYear        Int      @default(2025)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  accountant        Accountant         @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  subscription      Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  users             UserBusiness[]
  bankImports       BankImport[]
  transactions      Transaction[]
  categories        Category[]
  classificationRules ClassificationRule[]

  @@unique([accountantId, name])
  @@index([accountantId])
  @@index([subscriptionId])
  @@map("businesses")
}

// ============================================================================
// USER MANAGEMENT WITH MULTI-ROLE SUPPORT
// ============================================================================

// User roles
enum UserRole {
  OWNER    // Can manage everything
  MANAGER  // Can manage Business data, users within that Business
  VIEWER   // Read-only access
}

// User (can belong to multiple Businesses)
model User {
  id           String   @id @default(cuid())
  accountantId String
  email        String
  name         String?
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  accountant Accountant @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  businesses UserBusiness[]

  @@unique([accountantId, email])
  @@index([accountantId])
  @@map("users")
}

// Junction table: User <-> Business with role
model UserBusiness {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       UserRole @default(VIEWER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@map("users_businesses")
}

// ============================================================================
// FILE IMPORT & TRANSACTION DATA
// ============================================================================

// BankImport: Record each file upload
model BankImport {
  id                   String   @id @default(cuid())
  businessId           String
  bankFormatMappingId  String?  // Link to reusable mapping
  filename             String
  fileType             String   // "csv", "xlsx", "pdf"
  bankName             String?  // "Chase", "BofA", etc.
  importedDate         DateTime @default(now())
  transactionCount     Int
  mappingUsed          String   // JSON serialized column mapping (fallback/snapshot)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  business             Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bankFormatMapping    BankFormatMapping?    @relation(fields: [bankFormatMappingId], references: [id], onDelete: SetNull)
  transactions         Transaction[]

  @@index([businessId])
  @@index([bankFormatMappingId])
  @@index([importedDate])
  @@map("bank_imports")
}

// BankFormatMapping: Reusable column mappings by bank and accountant
// Example: Chase CSV layout, BofA XLSX layout, etc.
model BankFormatMapping {
  id           String   @id @default(cuid())
  accountantId String
  bankName     String   // "Chase", "BofA", "WellsFargo", etc.
  columnMapping String   // JSON: { "date": 0, "description": 1, "amount": 2, "type": 3 }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  accountant Accountant   @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  imports    BankImport[]

  @@unique([accountantId, bankName])
  @@index([accountantId])
  @@map("bank_format_mappings")
}

// Classification method enum
enum ClassificationMethod {
  MANUAL   // User manually assigned
  RULE     // Applied via ClassificationRule
  AI       // Applied via Claude API
}

// Classification status enum
enum TransactionStatus {
  PENDING      // Not yet classified
  CLASSIFIED   // Classified by AI or rule
  APPROVED     // Approved by user (final)
  REJECTED     // Rejected/flagged for review
}

// Deductibility enum
enum DeductibilityType {
  YES   // 100% deductible
  NO    // 0% deductible
  FIFTY // 50% deductible
}

// Transaction
// Note: If transaction has splits (TransactionSplit records), categoryId should be null
model Transaction {
  id                  String              @id @default(cuid())
  businessId          String
  bankImportId        String
  date                DateTime
  description         String
  amount              Decimal             @db.Decimal(12, 2)
  type                String              @default("DEBIT") // "DEBIT" or "CREDIT"

  // Classification fields
  categoryId          String?             // NULL if split across multiple categories
  ruleId              String?             // Reference to rule if method = RULE
  status              TransactionStatus   @default(PENDING)
  method              ClassificationMethod?
  deductibility       DeductibilityType   @default(NO)
  confidence          String?             // "HIGH", "MEDIUM", "LOW"
  irsLine             String?             // e.g., "Schedule C - Line 24a"

  // Audit fields
  classifiedAt        DateTime?
  classifiedBy        String?             // User ID who classified
  approvedAt          DateTime?
  approvedBy          String?             // User ID who approved

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  business            Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bankImport          BankImport           @relation(fields: [bankImportId], references: [id], onDelete: Cascade)
  category            Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  rule                ClassificationRule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  splits              TransactionSplit[]
  attachments         Attachment[]

  @@index([businessId])
  @@index([bankImportId])
  @@index([categoryId])
  @@index([ruleId])
  @@index([status])
  @@index([date])
  @@map("transactions")
}

// TransactionSplit: Support splitting a transaction across multiple categories
// Example: $1000 transaction split 60% to Travel (600) and 40% to Meals (400)
model TransactionSplit {
  id            String   @id @default(cuid())
  transactionId String
  categoryId    String
  amount        Decimal  @db.Decimal(12, 2)  // Amount allocated to this category
  percentage    Decimal  @db.Decimal(5, 2)   // Percentage (e.g., 60.00 for 60%)
  deductibility DeductibilityType            // Can override per split
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([categoryId])
  @@map("transaction_splits")
}

// Attachment: Store receipts, photos, PDFs, etc. linked to transactions
model Attachment {
  id            String   @id @default(cuid())
  transactionId String
  fileUrl       String   // S3/CloudStorage URL
  fileType      String   // "pdf", "jpg", "png", "receipt"
  fileName      String
  fileSize      Int      // Bytes
  uploadedAt    DateTime @default(now())
  notes         String?

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("attachments")
}

// ============================================================================
// CHART OF ACCOUNTS & CATEGORIZATION
// ============================================================================

// Category: Chart of accounts per Business
model Category {
  id          String   @id @default(cuid())
  businessId  String
  code        String   // e.g., "4100" (Chart of Accounts code)
  name        String   // e.g., "Travel Expenses"
  irsLine     String?  // e.g., "Schedule C - Line 24a"
  deductibility DeductibilityType @default(NO)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  business            Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  splits              TransactionSplit[]
  classificationRules ClassificationRule[]

  @@unique([businessId, code])
  @@index([businessId])
  @@map("categories")
}

// ClassificationRule: Manual rule-based classification
// If description contains keyword X, assign to category Y
model ClassificationRule {
  id         String   @id @default(cuid())
  businessId String
  categoryId String
  keyword    String   // Substring to match (case-insensitive)
  priority   Int      @default(0) // Higher = more priority
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
  @@index([categoryId])
  @@map("classification_rules")
}

// ============================================================================
// SUBSCRIPTION/PLAN - SEPARATED INTO CATALOG & INSTANCES
// ============================================================================

// Plan: Product catalog tier (BASIC, PLUS, ENTERPRISE with their feature sets)
enum PlanType {
  BASIC       // Basic plan: 1 business, 10K tx/yr, 3 users, $29/mo
  PLUS        // Pro plan: 5 businesses, 50K tx/yr, 10 users, AI enabled, $99/mo
  ENTERPRISE  // Custom: unlimited, $999/mo+
}

// SubscriptionStatus: Current state of a subscription
enum SubscriptionStatus {
  ACTIVE      // Subscription is active and valid
  PAST_DUE    // Payment pending
  CANCELED    // Subscription canceled
  SUSPENDED   // Suspended (e.g., due to billing)
}

model Plan {
  id             String   @id @default(cuid())
  accountantId   String
  type           PlanType @default(BASIC)
  maxBusinesses  Int      @default(1)
  maxTransactions Int     @default(10000)
  maxUsers       Int      @default(3)
  maxFileSize    Int      @default(10) // MB
  includeAI      Boolean  @default(false)
  pricePerMonth  Int      @default(2900) // Price in cents (e.g., 2900 = $29.00)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  accountant    Accountant    @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([accountantId])
  @@map("plans")
}

// Subscription: Actual subscription instance for an Accountant
// Links Accountant to a Plan type with start/renewal dates
model Subscription {
  id          String               @id @default(cuid())
  accountantId String
  planId      String
  status      SubscriptionStatus   @default(ACTIVE)
  startDate   DateTime             @default(now())
  renewsAt    DateTime
  canceledAt  DateTime?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Relations
  accountant Accountant @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  plan       Plan       @relation(fields: [planId], references: [id], onDelete: Restrict)
  businesses Business[]

  @@unique([accountantId])
  @@index([accountantId])
  @@index([planId])
  @@index([status])
  @@index([renewsAt])
  @@map("subscriptions")
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

enum AuditAction {
  TRANSACTION_CLASSIFIED
  TRANSACTION_APPROVED
  TRANSACTION_SPLIT
  ATTACHMENT_ADDED
  RULE_CREATED
  RULE_UPDATED
  USER_ADDED
  USER_REMOVED
}

model AuditLog {
  id        String      @id @default(cuid())
  businessId String
  action    AuditAction
  entityType String      // "Transaction", "ClassificationRule", "User", "TransactionSplit"
  entityId  String
  userId    String?     // Who performed the action
  details   String?     // JSON serialized details
  createdAt DateTime    @default(now())

  @@index([businessId])
  @@index([createdAt])
  @@map("audit_logs")
}
